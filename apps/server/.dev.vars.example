# Local secrets/vars for the Screener API Worker (Hono on Cloudflare Workers).
# Copy to `.dev.vars` for `wrangler dev`. `.dev.vars` is gitignored.
# In production set these with `wrangler secret put <NAME>` (never commit them).
#
# Non-secret vars (CORS_ORIGIN, D1 binding, etc.) live in wrangler.toml.

# Signs/verifies auth tokens.
JWT_SECRET=dev-secret-change-me-in-production

# Allowed browser origin for CORS (overrides wrangler.toml [vars] locally).
CORS_ORIGIN=http://localhost:3000

# Where the Worker proxies image analysis. Local YOLO server defaults to
# http://127.0.0.1:8765/analyze; a hosted model (e.g. HF Spaces) uses :7860.
INFERENCE_URL=http://127.0.0.1:8765/analyze

# Enables POST /api/dev/seed (admin + demo data). Leave unset in production.
SEED_ENABLED=true
